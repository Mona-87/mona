@app.route('/api/search', methods=['GET'])
def search():
    """搜索资源、帖子和课程"""
    query = request.args.get('q', '').strip()
    if not query:
        return jsonify({
            'success': True,
            'data': {
                'resources': [],
                'posts': [],
                'courses': []
            }
        })
    
    db = get_db()
    
    # 搜索资源
    resources = db.execute('''
    SELECT r.id, r.title, r.description, r.resource_type, r.course_name, 
           r.download_count, r.created_at, u.username
    FROM resources r
    JOIN users u ON r.user_id = u.id
    WHERE r.title LIKE ? OR r.description LIKE ? OR r.course_name LIKE ?
    ORDER BY r.created_at DESC
    LIMIT 10
    ''', (f'%{query}%', f'%{query}%', f'%{query}%')).fetchall()
    
    # 搜索帖子
    posts = db.execute('''
    SELECT p.id, p.title, p.content, p.view_count, p.reply_count, 
           p.created_at, u.username
    FROM forum_posts p
    JOIN users u ON p.user_id = u.id
    WHERE p.title LIKE ? OR p.content LIKE ? OR p.tags LIKE ?
    ORDER BY p.created_at DESC
    LIMIT 10
    ''', (f'%{query}%', f'%{query}%', f'%{query}%')).fetchall()
    
    # 搜索课程
    courses = db.execute('''
    SELECT id, name, description, resource_count, post_count
    FROM courses
    WHERE name LIKE ? OR description LIKE ?
    ORDER BY resource_count DESC
    LIMIT 10
    ''', (f'%{query}%', f'%{query}%')).fetchall()
    
    return jsonify({
        'success': True,
        'data': {
            'resources': [dict(resource) for resource in resources],
            'posts': [dict(post) for post in posts],
            'courses': [dict(course) for course in courses]
        }
    })

# 统计数据API
@app.route('/api/stats', methods=['GET'])
def get_stats():
    """获取平台统计数据"""
    db = get_db()
    
    # 资源统计
    resource_stats = db.execute('''
    SELECT 
        COUNT(*) as total_resources,
        SUM(download_count) as total_downloads,
        SUM(view_count) as total_views
    FROM resources
    ''').fetchone()
    
    # 用户统计
    user_stats = db.execute('''
    SELECT COUNT(*) as total_users FROM users
    ''').fetchone()
    
    # 论坛统计
    forum_stats = db.execute('''
    SELECT 
        COUNT(*) as total_posts,
        SUM(view_count) as total_post_views,
        SUM(reply_count) as total_replies
    FROM forum_posts
    ''').fetchone()
    
    # 热门课程
    popular_courses = db.execute('''
    SELECT name, resource_count, post_count
    FROM courses
    ORDER BY resource_count + post_count DESC
    LIMIT 5
    ''').fetchall()
    
    # 最近活动
    recent_resources = db.execute('''
    SELECT r.title, r.created_at, u.username
    FROM resources r
    JOIN users u ON r.user_id = u.id
    ORDER BY r.created_at DESC
    LIMIT 5
    ''').fetchall()
    
    recent_posts = db.execute('''
    SELECT p.title, p.created_at, u.username
    FROM forum_posts p
    JOIN users u ON p.user_id = u.id
    ORDER BY p.created_at DESC
    LIMIT 5
    ''').fetchall()
    
    return jsonify({
        'success': True,
        'data': {
            'resource_stats': dict(resource_stats),
            'user_stats': dict(user_stats),
            'forum_stats': dict(forum_stats),
            'popular_courses': [dict(course) for course in popular_courses],
            'recent_activity': {
                'resources': [dict(resource) for resource in recent_resources],
                'posts': [dict(post) for post in recent_posts]
            }
        }
    })

