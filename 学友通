@app.route('/api/resources', methods=['GET'])
def get_resources():
    """获取资源列表"""
    resource_type = request.args.get('type', '')
    course_name = request.args.get('course', '')
    page = int(request.args.get('page', 1))
    limit = int(request.args.get('limit', 20))
    offset = (page - 1) * limit
    
    db = get_db()
    
    # 构建查询条件
    conditions = []
    params = []
    
    if resource_type:
        conditions.append('r.resource_type = ?')
        params.append(resource_type)
    
    if course_name:
        conditions.append('r.course_name = ?')
        params.append(course_name)
    
    where_clause = ' AND '.join(conditions) if conditions else '1=1'
    
    # 获取资源总数
    count_query = f'''
    SELECT COUNT(*) as total 
    FROM resources r
    WHERE {where_clause}
    '''
    total_result = db.execute(count_query, params).fetchone()
    total = total_result['total']
    
    # 获取资源列表
    query = f'''
    SELECT r.*, u.username, u.avatar
    FROM resources r
    JOIN users u ON r.user_id = u.id
    WHERE {where_clause}
    ORDER BY r.created_at DESC
    LIMIT ? OFFSET ?
    '''
    params.extend([limit, offset])
    
    resources = db.execute(query, params).fetchall()
    
    resources_list = []
    for resource in resources:
        resource_dict = dict(resource)
        # 处理文件大小显示
        if resource_dict['filesize']:
            size = resource_dict['filesize']
            if size < 1024:
                resource_dict['file_size_display'] = f"{size}B"
            elif size < 1024 * 1024:
                resource_dict['file_size_display'] = f"{size/1024:.1f}KB"
            else:
                resource_dict['file_size_display'] = f"{size/(1024*1024):.1f}MB"
        else:
            resource_dict['file_size_display'] = "未知大小"
        
        # 处理时间显示
        created_at = resource_dict['created_at']
        if isinstance(created_at, str):
            try:
                created_at = datetime.fromisoformat(created_at.replace('Z', '+00:00'))
            except:
                created_at = datetime.now()
        
        time_diff = datetime.now() - created_at
        if time_diff.days > 365:
            resource_dict['time_display'] = f"{time_diff.days//365}年前"
        elif time_diff.days > 30:
            resource_dict['time_display'] = f"{time_diff.days//30}个月前"
        elif time_diff.days > 0:
            resource_dict['time_display'] = f"{time_diff.days}天前"
        elif time_diff.seconds > 3600:
            resource_dict['time_display'] = f"{time_diff.seconds//3600}小时前"
        elif time_diff.seconds > 60:
            resource_dict['time_display'] = f"{time_diff.seconds//60}分钟前"
        else:
            resource_dict['time_display'] = "刚刚"
        
        resources_list.append(resource_dict)
    
    return jsonify({
        'success': True,
        'data': {
            'resources': resources_list,
            'pagination': {
                'page': page,
                'limit': limit,
                'total': total,
                'pages': (total + limit - 1) // limit
            }
        }
    })

@app.route('/api/resources', methods=['POST'])
@login_required
def upload_resource():
    """上传资源"""
    if 'file' not in request.files:
        return jsonify({
            'success': False,
            'message': '没有上传文件',
            'code': 400
        }), 400
    
    file = request.files['file']
    if file.filename == '':
        return jsonify({
            'success': False,
            'message': '没有选择文件',
            'code': 400
        }), 400
    
    if not allowed_file(file.filename):
        return jsonify({
            'success': False,
            'message': f'不支持的文件类型，允许的类型: {", ".join(ALLOWED_EXTENSIONS)}',
            'code': 400
        }), 400
    
    # 获取表单数据
    title = request.form.get('title', '').strip()
    description = request.form.get('description', '').strip()
    resource_type = request.form.get('resource_type', '').strip()
    course_name = request.form.get('course_name', '').strip()
    
    if not title or not resource_type:
        return jsonify({
            'success': False,
            'message': '标题和资源类型不能为空',
            'code': 400
        }), 400
    
    # 生成安全的文件名
    filename = secure_filename(file.filename)
    # 添加时间戳防止重名
    file_extension = filename.rsplit('.', 1)[1].lower() if '.' in filename else ''
    unique_filename = f"{uuid.uuid4().hex}.{file_extension}" if file_extension else uuid.uuid4().hex
    
    # 保存文件
    filepath = os.path.join(app.config['UPLOAD_FOLDER'], unique_filename)
    file.save(filepath)
    
    # 获取文件信息
    filesize = os.path.getsize(filepath)
    
    # 保存到数据库
    db = get_db()
    try:
        cursor = db.execute('''
        INSERT INTO resources 
        (user_id, title, description, filename, filepath, filetype, filesize, resource_type, course_name)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (
            session['user_id'], title, description, filename, unique_filename, 
            file_extension, filesize, resource_type, course_name
        ))
        
        # 更新课程资源计数
        if course_name:
            db.execute('''
            UPDATE courses 
            SET resource_count = resource_count + 1 
            WHERE name = ?
            ''', (course_name,))
        
        db.commit()
        
        return jsonify({
            'success': True,
            'message': '资源上传成功',
            'data': {
                'resource_id': cursor.lastrowid,
                'title': title,
                'filename': filename
            }
        }), 201
    except Exception as e:
        # 删除已上传的文件
        if os.path.exists(filepath):
            os.remove(filepath)
        return jsonify({
            'success': False,
            'message': f'资源保存失败: {str(e)}',
            'code': 500
        }), 500

