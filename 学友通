            'UPDATE forum_posts SET reply_count = reply_count + 1 WHERE id = ?',
            (post_id,)
        )
        
        db.commit()
        
        return jsonify({
            'success': True,
            'message': '回复发布成功',
            'data': {
                'reply_id': cursor.lastrowid
            }
        }), 201
    except Exception as e:
        return jsonify({
            'success': False,
            'message': f'回复发布失败: {str(e)}',
            'code': 500
        }), 500

@app.route('/api/forum/replies/<int:reply_id>/upvote', methods=['POST'])
@login_required
def upvote_reply(reply_id):
    """点赞回复"""
    db = get_db()
    
    # 检查回复是否存在
    reply = db.execute(
        'SELECT id FROM forum_replies WHERE id = ?',
        (reply_id,)
    ).fetchone()
    
    if not reply:
        return jsonify({
            'success': False,
            'message': '回复不存在',
            'code': 404
        }), 404
    
    # 检查是否已经点赞
    existing_upvote = db.execute(
        'SELECT id FROM upvotes WHERE user_id = ? AND reply_id = ?',
        (session['user_id'], reply_id)
    ).fetchone()
    
    if existing_upvote:
        # 取消点赞
        db.execute(
            'DELETE FROM upvotes WHERE user_id = ? AND reply_id = ?',
            (session['user_id'], reply_id)
        )
        db.execute(
            'UPDATE forum_replies SET upvote_count = upvote_count - 1 WHERE id = ?',
            (reply_id,)
        )
        action = '取消点赞'
    else:
        # 点赞
        db.execute(
            'INSERT INTO upvotes (user_id, reply_id) VALUES (?, ?)',
            (session['user_id'], reply_id)
        )
        db.execute(
            'UPDATE forum_replies SET upvote_count = upvote_count + 1 WHERE id = ?',
            (reply_id,)
        )
        action = '点赞'
    
    db.commit()
    
    # 获取更新后的点赞数
    updated_reply = db.execute(
        'SELECT upvote_count FROM forum_replies WHERE id = ?',
        (reply_id,)
    ).fetchone()
    
    return jsonify({
        'success': True,
        'message': f'{action}成功',
        'data': {
            'upvote_count': updated_reply['upvote_count']
        }
    })

