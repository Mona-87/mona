        });
        
        document.getElementById('registerForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('注册成功！（演示模式）');
            hideModal('registerModal');
        });
        
        document.getElementById('askForm').addEventListener('submit', function(e) {
