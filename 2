# 1. 用户注册 (支持邮箱/QQ/微信模拟)
@app.route('/api/register', methods=['POST'])
def register():
    data = request.json
    username = data.get('username')
    password = data.get('password')
    email = data.get('email')
    third_party_type = data.get('third_party')  # 'qq' or 'wechat'
    third_party_id = data.get('third_party_id')
    
    if not username or not password:
        return jsonify({'error': '用户名和密码不能为空'}), 400
        
    password_hash = generate_password_hash(password)
    
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        
        if third_party_type == 'qq':
            cursor.execute('INSERT INTO users (username, password_hash, qq_openid) VALUES (?, ?, ?)',
                          (username, password_hash, third_party_id))
        elif third_party_type == 'wechat':
            cursor.execute('INSERT INTO users (username, password_hash, wechat_openid) VALUES (?, ?, ?)',
                          (username, password_hash, third_party_id))
        else:
            cursor.execute('INSERT INTO users (username, password_hash, email) VALUES (?, ?, ?)',
                          (username, password_hash, email))
        
        conn.commit()
        return jsonify({'message': '注册成功'}), 201
    except sqlite3.IntegrityError:
        return jsonify({'error': '用户名或邮箱已存在'}), 409
    finally:
        conn.close()

# 2. 用户登录
@app.route('/api/login', methods=['POST'])
def login():
    data = request.json
    username = data.get('username')
    password = data.get('password')
    
    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute('SELECT * FROM users WHERE username = ?', (username,))
    user = cursor.fetchone()
    conn.close()
    
    if user and check_password_hash(user['password_hash'], password):
        session['user_id'] = user['id']
        session['username'] = user['username']
        return jsonify({
            'message': '登录成功',
            'user_id': user['id'],
            'username': user['username']
        })
    return jsonify({'error': '用户名或密码错误'}), 401

# 3. 上传资源
@app.route('/api/resources/upload', methods=['POST'])
@login_required
def upload_resource():
    data = request.form
    title = data.get('title')
    description = data.get('description')
    resource_type = data.get('resource_type')
    course_name = data.get('course_name')
    
    # 模拟文件上传
    file = request.files.get('file')
    if not file:
        return jsonify({'error': '文件不能为空'}), 400
    
    # 保存文件 (实际应用中应保存到云存储)
    filename = f"{datetime.now().timestamp()}_{file.filename}"
    file_path = os.path.join('uploads', filename)
    os.makedirs('uploads', exist_ok=True)
    file.save(file_path)
    
    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute('''
    INSERT INTO resources (user_id, title, description, file_path, resource_type, course_name)
    VALUES (?, ?, ?, ?, ?, ?)
    ''', (session['user_id'], title, description, file_path, resource_type, course_name))
    conn.commit()
    resource_id = cursor.lastrowid
    conn.close()
    
    return jsonify({'message': '资源上传成功', 'resource_id': resource_id}), 201

# 4. 获取资源列表 (按课程/类型筛选)
@app.route('/api/resources', methods=['GET'])
def get_resources():
    course_name = request.args.get('course')
    resource_type = request.args.get('type')
    
    conn = get_db_connection()
    cursor = conn.cursor()
    
    query = 'SELECT r.*, u.username FROM resources r JOIN users u ON r.user_id = u.id'
    params = []
    conditions = []
    
    if course_name:
        conditions.append('r.course_name = ?')
        params.append(course_name)
    if resource_type:
        conditions.append('r.resource_type = ?')
        params.append(resource_type)
    
    if conditions:
        query += ' WHERE ' + ' AND '.join(conditions)
    
    query += ' ORDER BY r.created_at DESC'
    
    cursor.execute(query, params)
    resources = [dict(row) for row in cursor.fetchall()]
    conn.close()
    
    return jsonify(resources)

# 5. 下载资源
@app.route('/api/resources/<int:resource_id>/download', methods=['GET'])
@login_required
def download_resource(resource_id):
    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute('SELECT file_path FROM resources WHERE id = ?', (resource_id,))
    resource = cursor.fetchone()
    
    if not resource:
        conn.close()
        return jsonify({'error': '资源不存在'}), 404
    
    # 更新下载次数
    cursor.execute('UPDATE resources SET download_count = download_count + 1 WHERE id = ?', (resource_id,))
    conn.commit()
    conn.close()
    
    # 实际应返回文件流，这里简化返回路径
    return jsonify({'message': '下载成功', 'file_path': resource['file_path']})

